---
import now from '../content/now.json';
---

<div class="now-block">
  <p class="now-label">Now</p>
  <p class="now-focus">{now.focus}</p>
  <dl class="now-meta">
    <div class="now-item">
      <dt>Reading</dt>
      <dd>{now.reading}</dd>
    </div>
    <div class="now-item">
      <dt>Building</dt>
      <dd>{now.building}</dd>
    </div>
  </dl>
  <p class="now-updated">Updated {now.updated}</p>
</div>

<style>
.now-block {
  border: 1px solid var(--color-border);
  border-radius: 8px;
  padding: var(--space-8);
  background: var(--color-surface);
  max-width: 36rem;
}
.now-label {
  font-size: var(--text-xs);
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-accent);
  margin-bottom: var(--space-3);
  line-height: 1;
}
.now-focus {
  font-family: var(--font-display);
  font-size: var(--text-lg);
  color: var(--color-text-primary);
  line-height: 1.4;
  margin-bottom: var(--space-6);
}
.now-meta {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  margin-bottom: var(--space-6);
}
.now-item {
  display: flex;
  gap: var(--space-3);
  font-size: var(--text-sm);
}
.now-item dt {
  color: var(--color-text-tertiary);
  min-width: 5rem;
  flex-shrink: 0;
}
.now-item dd {
  color: var(--color-text-secondary);
}
.now-updated {
  font-size: var(--text-xs);
  color: var(--color-text-tertiary);
  line-height: 1;
}
</style>
